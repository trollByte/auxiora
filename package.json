{
  "name": "auxiora-monorepo",
  "version": "1.10.13",
  "private": true,
  "description": "Personal AI assistant with encrypted credential vault",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && find packages -name '*.tsbuildinfo' -delete",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "desktop:dev": "pnpm --filter @auxiora/desktop dev",
    "desktop:build": "pnpm --filter @auxiora/desktop build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "axios@>=1.0.0 <1.13.5": ">=1.13.5",
      "undici@<6.23.0": ">=6.23.0",
      "qs@>=6.7.0 <6.14.2": ">=6.14.2"
    }
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
