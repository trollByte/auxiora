{
  "name": "@auxiora/behaviors",
  "version": "1.10.1",
  "description": "Proactive behaviors: scheduled tasks, monitors, and one-shot reminders",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/core": "workspace:*",
    "@auxiora/errors": "workspace:*",
    "@auxiora/job-queue": "workspace:^",
    "@auxiora/logger": "workspace:*",
    "@auxiora/audit": "workspace:*",
    "node-cron": "^3.0.3",
    "nanoid": "^5.1.2"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
