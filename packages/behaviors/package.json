{
  "name": "@auxiora/behaviors",
  "version": "1.10.13",
  "description": "Proactive behaviors: scheduled tasks, monitors, and one-shot reminders",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/audit": "workspace:*",
    "@auxiora/core": "workspace:*",
    "@auxiora/errors": "workspace:*",
    "@auxiora/job-queue": "workspace:*",
    "@auxiora/logger": "workspace:*",
    "croner": "^10.0.1",
    "nanoid": "^5.1.2"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
