    "@auxiora/marketplace": "workspace:*",
    "@auxiora/memory": "workspace:*",
    "@auxiora/plugins": "workspace:*",
    "@auxiora/providers": "workspace:*",
    "@auxiora/router": "workspace:*",
    "@auxiora/daemon": "workspace:*",
    "@auxiora/gateway": "workspace:*",
    "@auxiora/onboarding": "workspace:*",
    "@auxiora/personality": "workspace:*",
    "@auxiora/runtime": "workspace:*",
    "@auxiora/vault": "workspace:*",
    "@auxiora/connectors": "workspace:*",
    "@auxiora/connector-google-workspace": "workspace:*",
    "@auxiora/connector-github": "workspace:*",
