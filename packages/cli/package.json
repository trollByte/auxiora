{
  "name": "@auxiora/cli",
  "version": "1.0.0",
  "description": "CLI for Auxiora AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "auxiora": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@auxiora/audit": "workspace:*",
    "@auxiora/config": "workspace:*",
    "@auxiora/core": "workspace:*",
    "@auxiora/daemon": "workspace:*",
    "@auxiora/gateway": "workspace:*",
    "@auxiora/runtime": "workspace:*",
    "@auxiora/vault": "workspace:*",
    "@inquirer/prompts": "^8.2.0",
    "argon2": "^0.44.0",
    "commander": "^14.0.3",
    "jsonwebtoken": "^9.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9"
  }
}
