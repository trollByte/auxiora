{
  "name": "@auxiora/router",
  "version": "1.10.13",
  "description": "Model routing engine for Auxiora - task classification, model selection, and cost tracking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/core": "workspace:*",
    "@auxiora/config": "workspace:*",
    "@auxiora/logger": "workspace:*",
    "@auxiora/providers": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
