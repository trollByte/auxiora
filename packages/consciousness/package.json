{
  "name": "@auxiora/consciousness",
  "version": "1.10.20",
  "description": "Unified consciousness layer — persistent self-awareness, self-monitoring, self-repair, and self-model",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
