{
  "name": "@auxiora/runtime",
  "version": "1.0.0",
  "description": "Runtime that connects all Auxiora components",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/audit": "workspace:*",
    "@auxiora/behaviors": "workspace:*",
    "@auxiora/browser": "workspace:*",
    "@auxiora/stt": "workspace:*",
    "@auxiora/tts": "workspace:*",
    "@auxiora/voice": "workspace:*",
    "@auxiora/channels": "workspace:*",
    "@auxiora/config": "workspace:*",
    "@auxiora/core": "workspace:*",
    "@auxiora/gateway": "workspace:*",
    "@auxiora/providers": "workspace:*",
    "@auxiora/sessions": "workspace:*",
    "@auxiora/tools": "workspace:*",
    "@auxiora/vault": "workspace:*",
    "@auxiora/webhooks": "workspace:*",
    "@auxiora/dashboard": "workspace:*",
    "@auxiora/plugins": "workspace:*",
    "@auxiora/memory": "workspace:*",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
