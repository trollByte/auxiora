{
  "name": "@auxiora/channels",
  "version": "1.3.1",
  "description": "Channel adapters for Discord, Telegram, Slack, and Twilio",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/audit": "workspace:*",
    "@auxiora/logger": "workspace:*",
    "@auxiora/core": "workspace:*",
    "@grammyjs/types": "^3.16.0",
    "@slack/bolt": "^4.3.0",
    "discord.js": "^14.18.0",
    "grammy": "^1.35.0",
    "twilio": "^5.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
