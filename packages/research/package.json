{
  "name": "@auxiora/research",
  "version": "1.10.6",
  "description": "Deep multi-source research agent with citation tracking and knowledge graph",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/logger": "workspace:*",
    "@auxiora/audit": "workspace:*",
    "@auxiora/ssrf-guard": "workspace:*",
    "nanoid": "^5.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
