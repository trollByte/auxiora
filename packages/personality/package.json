{
  "name": "@auxiora/personality",
  "version": "1.10.17",
  "description": "Personality templates and SOUL.md management for Auxiora",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./architect": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@auxiora/config": "workspace:*",
    "@auxiora/core": "workspace:*",
    "@auxiora/self-awareness": "workspace:*",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "lib/"
  ]
}
