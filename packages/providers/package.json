{
  "name": "@auxiora/providers",
  "version": "1.10.12",
  "description": "AI provider adapters for Auxiora",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@auxiora/core": "workspace:*",
    "@auxiora/logger": "workspace:*",
    "@auxiora/vault": "workspace:*",
    "@google/generative-ai": "^0.24.0",
    "openai": "^4.103.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
