{
  "name": "@auxiora/ambient",
  "version": "1.10.7",
  "description": "Ambient pattern detection, anticipation, briefings, and quiet notifications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxiora/behaviors": "workspace:*",
    "@auxiora/memory": "workspace:*",
    "@auxiora/connectors": "workspace:*",
    "@auxiora/notification-hub": "workspace:*",
    "@auxiora/personality": "workspace:*",
    "@auxiora/self-awareness": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ]
}
