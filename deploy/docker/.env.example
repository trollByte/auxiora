# Auxiora Docker Compose Configuration
# Copy this file to .env and edit as needed

# ── Auxiora Gateway ──────────────────────────────────────────────
AUXIORA_PORT=18800
AUXIORA_DASHBOARD_ENABLED=true
AUXIORA_METRICS_ENABLED=true

# ── Database (enable with: docker compose --profile postgres up) ─
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://auxiora:changeme@postgres:5432/auxiora

# ── Redis (enable with: docker compose --profile redis up) ───────
REDIS_URL=redis://redis:6379

# ── Monitoring (enable with: docker compose --profile monitoring up)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── All services (enable with: docker compose --profile full up) ─
# The "full" profile starts postgres, redis, prometheus, and grafana

# ── AI Provider Keys (set the ones you use) ──────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# COHERE_API_KEY=
# XAI_API_KEY=
# REPLICATE_API_TOKEN=
