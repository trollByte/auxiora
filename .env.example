# Auxiora Configuration
# Copy this file to .env and fill in your values (or use the encrypted vault instead)

# ============================================================================
# SECURITY WARNING
# ============================================================================
# .env files are NOT secure! Environment variables leak into:
# - Process listings (ps aux)
# - Child processes
# - Crash dumps
# - System logs
#
# RECOMMENDED: Use the encrypted vault instead:
#   auxiora vault add ANTHROPIC_API_KEY
#   auxiora vault add DISCORD_BOT_TOKEN
#
# Only use .env for non-sensitive configuration overrides.
# ============================================================================

# ----------------------------------------------------------------------------
# AI Provider Configuration
# ----------------------------------------------------------------------------

# Anthropic (Claude)
# Get your API key from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Anthropic OAuth Token (Claude Pro/Max users)
# Get via: claude setup-token
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# OpenAI (GPT models)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Primary Provider (default: anthropic)
# Options: anthropic | openai
# AUXIORA_PROVIDER_PRIMARY=anthropic

# Fallback Provider (default: none)
# AUXIORA_PROVIDER_FALLBACK=openai

# Model Selection
# AUXIORA_PROVIDER_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# AUXIORA_PROVIDER_OPENAI_MODEL=gpt-4o

# Max Tokens per Response
# AUXIORA_PROVIDER_ANTHROPIC_MAX_TOKENS=4096
# AUXIORA_PROVIDER_OPENAI_MAX_TOKENS=4096

# ----------------------------------------------------------------------------
# Gateway Configuration
# ----------------------------------------------------------------------------

# Gateway HTTP Server
# AUXIORA_GATEWAY_HOST=127.0.0.1  # SECURITY: Only localhost by default
# AUXIORA_GATEWAY_PORT=18789

# JWT Authentication
# AUXIORA_GATEWAY_JWT_SECRET=your-random-secret-here  # Generate with: openssl rand -hex 32
# AUXIORA_GATEWAY_JWT_EXPIRY=1h
# AUXIORA_GATEWAY_JWT_REFRESH_EXPIRY=7d

# Authentication Mode
# AUXIORA_GATEWAY_AUTH_MODE=jwt  # Options: jwt | none (DANGEROUS)

# Rate Limiting
# AUXIORA_GATEWAY_RATE_LIMIT_ENABLED=true
# AUXIORA_GATEWAY_RATE_LIMIT_MAX_REQUESTS=100
# AUXIORA_GATEWAY_RATE_LIMIT_WINDOW_MINUTES=15

# DM Pairing System
# AUXIORA_GATEWAY_PAIRING_ENABLED=true
# AUXIORA_GATEWAY_PAIRING_CODE_EXPIRY_MINUTES=10
# AUXIORA_GATEWAY_PAIRING_REQUIRE_CONFIRMATION=true

# ----------------------------------------------------------------------------
# Channel Configuration
# ----------------------------------------------------------------------------

# Discord Bot
# Get token from: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=...
# AUXIORA_CHANNELS_DISCORD_ENABLED=true
# AUXIORA_CHANNELS_DISCORD_MENTION_ONLY=true

# Telegram Bot
# Get token from: @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=...
# AUXIORA_CHANNELS_TELEGRAM_ENABLED=true

# Slack App
# Get tokens from: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# AUXIORA_CHANNELS_SLACK_ENABLED=true

# Twilio (SMS/WhatsApp)
# Get credentials from: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890
# AUXIORA_CHANNELS_TWILIO_ENABLED=false

# ----------------------------------------------------------------------------
# Session Management
# ----------------------------------------------------------------------------

# Session Configuration
# AUXIORA_SESSION_MAX_CONTEXT_TOKENS=100000
# AUXIORA_SESSION_TTL_MINUTES=1440  # 24 hours
# AUXIORA_SESSION_AUTO_SAVE=true
# AUXIORA_SESSION_COMPACTION_ENABLED=true

# ----------------------------------------------------------------------------
# File Paths (XDG-compliant by default)
# ----------------------------------------------------------------------------

# Override default paths if needed
# AUXIORA_VAULT_PATH=~/.auxiora/vault.enc
# AUXIORA_CONFIG_PATH=~/.auxiora/config.json
# AUXIORA_AUDIT_LOG_PATH=~/.auxiora/audit.jsonl
# AUXIORA_SESSIONS_DIR=~/.auxiora/sessions
# AUXIORA_WORKSPACE_PATH=~/.auxiora/workspace

# ----------------------------------------------------------------------------
# Security & Audit
# ----------------------------------------------------------------------------

# Audit Logging
# AUXIORA_AUDIT_ENABLED=true
# AUXIORA_AUDIT_REDACT_SENSITIVE=true

# Prompt Injection Detection
# AUXIORA_SECURITY_PROMPT_INJECTION_DETECTION=true
# AUXIORA_SECURITY_PROMPT_INJECTION_ACTION=log  # Options: log | block

# Input Sanitization
# AUXIORA_SECURITY_MAX_MESSAGE_LENGTH=32768
# AUXIORA_SECURITY_STRIP_NULL_BYTES=true

# ----------------------------------------------------------------------------
# Development & Debugging
# ----------------------------------------------------------------------------

# Log Level
# AUXIORA_LOG_LEVEL=info  # Options: debug | info | warn | error

# Enable Debug Mode
# AUXIORA_DEBUG=false

# Disable Vault (DANGEROUS - for testing only)
# AUXIORA_VAULT_DISABLED=false

# ----------------------------------------------------------------------------
# Daemon Configuration
# ----------------------------------------------------------------------------

# Auto-restart on failure
# AUXIORA_DAEMON_AUTO_RESTART=true

# Restart delay (seconds)
# AUXIORA_DAEMON_RESTART_DELAY=5

# Max restart attempts
# AUXIORA_DAEMON_MAX_RESTARTS=5

# ----------------------------------------------------------------------------
# Example: Minimal Setup
# ----------------------------------------------------------------------------
# 1. Add your API key to the vault (RECOMMENDED):
#    auxiora vault add ANTHROPIC_API_KEY
#
# 2. Or use this .env (NOT RECOMMENDED):
#    ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
#
# 3. Start Auxiora:
#    auxiora start
#
# 4. Open http://localhost:18789 in your browser
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Example: Multi-Channel Setup
# ----------------------------------------------------------------------------
# 1. Add credentials to vault:
#    auxiora vault add ANTHROPIC_API_KEY
#    auxiora vault add DISCORD_BOT_TOKEN
#    auxiora vault add TELEGRAM_BOT_TOKEN
#
# 2. Enable channels:
#    AUXIORA_CHANNELS_DISCORD_ENABLED=true
#    AUXIORA_CHANNELS_TELEGRAM_ENABLED=true
#
# 3. Start Auxiora:
#    auxiora start
# ----------------------------------------------------------------------------
