# Dependencies
**/node_modules

# Build output
packages/*/dist/
**/*.tsbuildinfo

# Version control
.git/
.gitignore

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Test and coverage
coverage/
*.test.ts
*.spec.ts
__tests__/

# Environment and secrets
.env
.env.*
*.pem
*.key

# Docker
deploy/docker/Dockerfile
.dockerignore

# Build artifacts
dist/
installers/

# Tauri / Rust build artifacts (biggest offender — ~3GB+)
packages/desktop/src-tauri/target/
packages/desktop/src-tauri/gen/
packages/desktop/dist-webview/

# Cargo lock not needed in Docker
packages/desktop/src-tauri/Cargo.lock

# Dashboard pre-built UI (rebuilt from source)
packages/dashboard/dist-ui/

# Demo files
demo-*.html

# Docs/plans (not needed at runtime)
docs/

# Miscellaneous
*.log
*.tgz
.DS_Store
PROMPT.md
